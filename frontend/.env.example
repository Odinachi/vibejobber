# Firebase — Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: Gen2 region for `apply_to_job` URL (default us-central1) — see `src/lib/applyAgent.ts`
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# In Firebase Console: Authentication → Sign-in method → enable Google and Apple (Sign in with Apple).
